{
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(/.env)",
      "Read(/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(/.env)",
      "Edit(/.env.*)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Bash(cat .env)",
      "Bash(cat /.env)",
      "Bash(cat **/.pem)",
      "Bash(cat **/.key)",
      "Bash(head .env)",
      "Bash(head /.env)",
      "Bash(tail .env)",
      "Bash(tail /.env)",
      "Bash(grep * .env)",
      "Bash(grep * */.env)",

      "Read(**/vendor/**)",
      "Read(**/dist/**)",
      "Read(**/build/**)",
      "Read(**/out/**)",
      "Read(**/coverage/**)",
      "Edit(**/node_modules/**)",
      "Edit(**/vendor/**)",
      "Edit(**/dist/**)",
      "Edit(**/build/**)",
      "Edit(**/out/**)",
      "Edit(**/coverage/**)",

      "Read(**/package-lock.json)",
      "Read(**/yarn.lock)",
      "Read(**/pnpm-lock.yaml)",
      "Edit(**/package-lock.json)",
      "Edit(**/yarn.lock)",
      "Edit(**/pnpm-lock.yaml)",

      "Read(**/*.min.js)",
      "Read(**/*.map)",
      "Edit(**/*.min.js)",
      "Edit(**/*.map)",

      "Read(**/*.log)",
      "Read(**/*.tmp)",
      "Edit(**/*.log)",
      "Edit(**/*.tmp)",

      "Read(**/*.mp3)",
      "Read(**/*.png)",
      "Read(**/*.svg)",
      "Edit(**/*.mp3)",
      "Edit(**/*.png)",
      "Edit(**/*.svg)",

      "Read(.git/**)",
      "Edit(.git/**)",

      "Bash(sudo:*)",
      "Bash(chmod 777:*)",
      "Bash(rm -rf /:*)"
    ],
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Skill(*)",

      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git --no-pager status *)",
      "Bash(git diff *)",
      "Bash(git --no-pager diff *)",
      "Bash(git log *)",
      "Bash(git --no-pager log *)",
      "Bash(git show *)",
      "Bash(git --no-pager show *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git --no-pager branch *)",
      "Bash(npm run lint)",
      "Bash(npm run test)",
      "Bash(npm run build)"
    ]
  }
}
